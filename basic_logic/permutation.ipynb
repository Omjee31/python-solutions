   "source": [
    "def permutations(s, current=\"\"):\n",
    "    if len(s) == 0:\n",
    "        print(current)\n",
    "        return\n",
    "    \n",
    "    for i in range(len(s)):\n",
    "        char = s[i]\n",
    "        remaining = s[:i] + s[i+1:]\n",
    "        permutations(remaining, current + char)\n",
    "\n",
    "\n",
    "permutations(\"AB\")"
   ]
  },
